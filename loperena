<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vota 01 - Jornada Mañana</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Arial, sans-serif; }
        
        body {
            background: linear-gradient(-45deg, #ff69b4, #ffd84d, #9b59b6, #ff1493);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; padding: 20px;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .container { width: 100%; max-width: 450px; }

        .card {
            background: rgba(255, 255, 255, 0.98);
            padding: 25px; border-radius: 25px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            text-align: center; margin-bottom: 20px;
            animation: fadeIn 0.6s ease;
        }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        h1 { color: #ff1493; font-size: 26px; margin-bottom: 10px; }
        h2 { color: #8e44ad; margin-bottom: 15px; }
        
        .propuesta-item {
            text-align: left; background: #f9f9f9;
            padding: 15px; border-left: 5px solid #ff1493;
            margin-bottom: 12px; border-radius: 8px;
        }

        .propuesta-item b { color: #ff1493; display: block; margin-bottom: 5px; }

        input {
            width: 100%; padding: 12px; margin: 8px 0;
            border-radius: 12px; border: 1px solid #ddd; outline: none;
        }

        button {
            width: 100%; padding: 16px; border: none;
            border-radius: 30px; color: white; font-weight: bold;
            font-size: 16px; cursor: pointer; transition: 0.3s;
            margin-top: 10px;
        }

        .btn-principal { background: #ff1493; box-shadow: 0 4px 12px rgba(255, 20, 147, 0.3); }
        .btn-apoyo { background: #8e44ad; box-shadow: 0 4px 12px rgba(142, 68, 173, 0.3); }
        
        button:hover { transform: scale(1.03); opacity: 0.9; }

        img {
            width: 100%; border-radius: 15px;
            margin: 10px 0; border: 3px solid #fff;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .hidden { display: none; }
        #mensaje { font-weight: bold; color: #2ecc71; margin-top: 15px; }
    </style>
</head>
<body>

<div class="container">
    <div id="login" class="card">
        <h1>VOTA 01 ❤️💜</h1>
        <p>Institución Educativa Loperena</p>
        <p><b>Jornada Mañana - 2026</b></p>
        <input type="text" id="nombre" placeholder="Escribe tu nombre">
        <input type="text" id="grado" placeholder="Escribe tu grado">
        <button class="btn-principal" onclick="irAFotos()">Conocer Candidatas ❤️💜</button>
    </div>

    <div id="fotos" class="card hidden">
        <h2>Nuestras Candidatas</h2>
        <img src="IMG-20260225-WA0044.jpg" alt="Candidata 1">
        <img src="IMG-20260225-WA0046.jpg" alt="Candidata 2">
        <button class="btn-principal" onclick="irAPropuestas()">Ver Propuestas Detalladas ✨</button>
    </div>

    <div id="propuestas" class="card hidden">
        <h2>Propuestas de Valor</h2>
        
        <div class="propuesta-item">
            <b>🎀 Participación Estudiantil Real</b>
            No solo seremos su voz, crearemos un comité de voceros por grado para que cada decisión importante del colegio sea consultada con ustedes.
        </div>

        <div class="propuesta-item">
            <b>💜 Transparencia y Control</b>
            Haremos rendición de cuentas pública cada periodo. Sabrán exactamente en qué se invierten los recursos de la jornada mañana.
        </div>

        <div class="propuesta-item">
            <b>⚽ Cultura y Deporte Activo</b>
            Gestión de campeonatos intercursos más organizados y espacios de talento artístico (danza, música y arte) durante los descansos pedagógicos.
        </div>

        <div class="propuesta-item">
            <b>🌿 Bienestar Escolar</b>
            Promoveremos jornadas de salud mental y espacios de diálogo para mejorar la convivencia y el apoyo entre compañeros.
        </div>

        <button id="btnApoyar" class="btn-apoyo" onclick="enviarApoyo()">¡SÍ, APOYO LA LISTA 01! ❤️💜</button>
        <p id="mensaje"></p>
    </div>
</div>

<script>
    function irAFotos() {
        const n = document.getElementById('nombre').value;
        const g = document.getElementById('grado').value;
        if(n && g) {
            localStorage.setItem('v_nom', n);
            localStorage.setItem('v_gra', g);
            document.getElementById('login').classList.add('hidden');
            document.getElementById('fotos').classList.remove('hidden');
            window.scrollTo(0,0);
        } else { alert('Escribe tu nombre y grado para continuar'); }
    }

    function irAPropuestas() {
        document.getElementById('fotos').classList.add('hidden');
        document.getElementById('propuestas').classList.remove('hidden');
        window.scrollTo(0,0);
    }

    function enviarApoyo() {
        const btn = document.getElementById('btnApoyar');
        btn.disabled = true;
        btn.innerText = "Registrando tu apoyo...";

        // Usamos Formspree para que te llegue el aviso
        fetch("https://formspree.io/f/mbdaqkeq", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                Nombre: localStorage.getItem('v_nom'),
                Grado: localStorage.getItem('v_gra'),
                Mensaje: "¡Nuevo apoyo total a la 01!"
            })
        }).then(() => {
            document.getElementById('mensaje').innerText = "¡Gracias! Tu apoyo ha sido registrado. ¡Juntos ganamos! ❤️💜";
            btn.innerText = "¡APOYO ENVIADO!";
        });
    }
</script>

</body>
</html>
